PINECONE_API_KEY=
PINECONE_INDEX=adal-theses
# Local Ollama embedding model (native /api/embed). Index dimension locks to it.
# `ollama pull bge-m3` -> 1024 dims, 8192-token context. Ollama must run.
EMBEDDING_MODEL=ollama/bge-m3
EMBED_DIM=1024
OLLAMA_BASE_URL=localhost:11434
# Retrieval tuning: chunks per query and the cosine-score floor. bge-m3 scores
# are compressed (noise ~0.44-0.49, real matches ~0.55-0.75), hence 0.50.
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.50
RETRIEVAL_MIN_SCORE_FILTERED=0.40   # floor when a program/year filter scopes the query
# Chat models the frontend may offer, in menu order (first = default). The API
# validates the user's pick against this list. Mix local (ollama/<name>) + cloud.
LLM_MODELS=ollama/qwen3.5:latest,mistral/mistral-small-latest
CHAT_FALLBACK_MODEL=ollama/qwen3.5:latest   # tried if the chosen model errors (local = free/always up)
OLLAMA_THINK=false        # keep off: thinking models waste the token budget for RAG
LLM_NUM_PREDICT=1536      # max answer length (tokens)
OLLAMA_NUM_CTX=16384      # context window to allocate (default = model max -> huge KV cache)
OLLAMA_KEEP_ALIVE=-1      # keep models loaded (-1 = forever); avoids cold reloads after idle
MISTRAL_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FRONTEND_ORIGIN=http://localhost:5173
