PINECONE_API_KEY=
PINECONE_INDEX=adal-theses
# Local Ollama embedding model (native /api/embed). Index dimension locks to it.
# `ollama pull bge-m3` -> 1024 dims, 8192-token context. Ollama must run.
EMBEDDING_MODEL=ollama/bge-m3
EMBED_DIM=1024
OLLAMA_BASE_URL=localhost:11434
LLM_MODELS=gemini/gemini-2.5-flash,gpt-5-mini   # first = primary, rest = fallbacks
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FRONTEND_ORIGIN=http://localhost:5173
