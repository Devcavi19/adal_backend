EMBED_DIM=1024
OLLAMA_BASE_URL=https://reveler-hankering-pancreas.ngrok-free.dev
LLM_MODELS=gemini/gemini-2.5-flash,gpt-5-mini   # first = primary, rest = fallbacks
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FRONTEND_ORIGIN=http://localhost:5173
