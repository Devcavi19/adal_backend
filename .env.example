PINECONE_API_KEY=
PINECONE_INDEX=adal-theses
# Local Ollama embedding model (via LiteLLM). Index dimension is locked to it.
# `ollama pull bge-m3` -> 1024 dims, 8192-token context. Requires Ollama running.
